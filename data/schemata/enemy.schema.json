{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "enemy.schema.json",
	"title": "Enemies",
	"type": "array",
	"items": {
		"type": "object",
		"additionalProperties": false,
		"required": [
			"id",
			"name",
			"description",
			"persona",
			"race_id",
			"archetype_id",
			"weapon_ids"
		],
		"properties": {
			"id": {
				"type": "string",
				"pattern": "^[a-z][a-z0-9_]*$"
			},
			"name": { "type": "string", "minLength": 1 },
			"description": { "type": "string" },
			"persona": { "type": "string" },
			"race_id": {
				"description": "Cross-reference to races.json -> race.id",
				"type": "string",
				"pattern": "^[a-z][a-z0-9_]*$"
			},
			"archetype_id": {
				"description": "Cross-reference to archetypes.json -> archetype.id",
				"type": "string",
				"pattern": "^[a-z][a-z0-9_]*$"
			},
			"weapon_ids": {
				"description": "Cross-reference to weapons.json -> weapon.id",
				"type": "array",
				"items": {
					"type": "string",
					"pattern": "^[a-z][a-z0-9_]*$"
				},
				"uniqueItems": true
			}
		}
	}
}
