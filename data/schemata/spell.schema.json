{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "spell.schema.json",
	"title": "Spells",
	"type": "array",
	"items": {
		"type": "object",
		"additionalProperties": false,
		"required": ["id", "name", "description", "type", "spell_cost", "parameters"],
		"properties": {
			"id": {
				"type": "string",
				"pattern": "^[a-z][a-z0-9_]*$"
			},
			"name": { "type": "string", "minLength": 1 },
			"description": { "type": "string" },
			"type": {
				"oneOf": [
					{
						"type": "string",
						"enum": [
							"attack",
							"heal",
							"buff",
							"debuff",
							"control",
							"cleanse",
							"aoe_attack",
							"aoe_heal",
							"aoe_buff",
							"aoe_debuff",
							"aoe_control",
							"aoe_cleanse"
						]
					},
					{
						"type": "array",
						"minItems": 1,
						"uniqueItems": true,
						"items": {
							"type": "string",
							"enum": [
								"attack",
								"heal",
								"buff",
								"debuff",
								"control",
								"cleanse",
								"aoe_attack",
								"aoe_heal",
								"aoe_buff",
								"aoe_debuff",
								"aoe_control",
								"aoe_cleanse"
							]
						},
						"allOf": [
							{
								"not": {
									"allOf": [
										{"contains": {"const": "attack"}},
										{"contains": {"const": "aoe_attack"}}
									]
								}
							},
							{
								"not": {
									"allOf": [
										{"contains": {"const": "heal"}},
										{"contains": {"const": "aoe_heal"}}
									]
								}
							},
							{
								"not": {
									"allOf": [
										{"contains": {"const": "buff"}},
										{"contains": {"const": "aoe_buff"}}
									]
								}
							},
							{
								"not": {
									"allOf": [
										{"contains": {"const": "debuff"}},
										{"contains": {"const": "aoe_debuff"}}
									]
								}
							},
							{
								"not": {
									"allOf": [
										{"contains": {"const": "control"}},
										{"contains": {"const": "aoe_control"}}
									]
								}
							},
							{
								"not": {
									"allOf": [
										{"contains": {"const": "cleanse"}},
										{"contains": {"const": "aoe_cleanse"}}
									]
								}
							}
						]
					}
				]
			},
			"spell_cost": { "type": "integer", "minimum": 0 },
			"parameters": {
				"type": "object",
				"additionalProperties": false,
				"properties": {
					"cleanse_status_effect_types": {
						"type": "array",
						"items": {
							"type": "string",
							"enum": [
								"attack_modifier",
								"ac_modifier",
								"DoT",
								"HoT",
								"control",
								"cc_immunity",
								"immunity",
								"resistance",
								"vulnerable"
							]
						},
						"uniqueItems": true
					},
					"cleanse_control_types": {
						"type": "array",
						"items": {
							"type": "string",
							"enum": ["stunned", "asleep", "restrained", "silenced"]
						},
						"uniqueItems": true
					},
					"damage_types": {
						"type": "array",
						"items": {
							"type": "string",
							"enum": [
								"acid",
								"bludgeoning",
								"cold",
								"fire",
								"force",
								"lightning",
								"necrotic",
								"piercing",
								"poison",
								"psychic",
								"radiant",
								"slashing",
								"thunder"
							]
						},
						"uniqueItems": true
					},
					"damage_roll": { "type": "string", "minLength": 1 },
					"heal_roll": { "type": "string", "minLength": 1 },
					"hit_modifiers": { "type": "integer" },
					"DC": { "type": "integer", "minimum": 0 },
					"applied_status_effects": {
						"description": "Per-application status effects with their own durations",
						"type": "array",
						"items": {
							"type": "object",
							"additionalProperties": false,
							"required": ["status_effect_id", "duration"],
							"properties": {
								"status_effect_id": {
									"description": "Cross-reference to status_effects.json -> status_effect.id",
									"type": "string",
									"pattern": "^[a-z][a-z0-9_]*$"
								},
								"duration": {
									"type": "integer",
									"minimum": 0
								}
							}
						}
					}
				}
			}
		}
	}
}
