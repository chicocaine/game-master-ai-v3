{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "spell.schema.json",
	"title": "Spells",
	"type": "array",
	"items": {
		"type": "object",
		"additionalProperties": false,
		"required": ["id", "name", "description", "type", "spell_cost", "parameters"],
		"properties": {
			"id": {
				"type": "string",
				"pattern": "^[a-z][a-z0-9_]*$"
			},
			"name": { "type": "string", "minLength": 1 },
			"description": { "type": "string" },
			"type": {
				"type": "string",
				"enum": [
					"attack",
					"heal",
					"buff",
					"debuff",
					"control",
					"cleanse",
					"aoe_attack",
					"aoe_heal",
					"aoe_buff",
					"aoe_debuff",
					"aoe_control",
					"aoe_cleanse"
				]
			},
			"spell_cost": { "type": "integer", "minimum": 0 },
			"parameters": {
				"type": "object",
				"additionalProperties": false,
				"properties": {
					"damage_types": {
						"type": "array",
						"items": {
							"type": "string",
							"enum": [
								"acid",
								"bludgeoning",
								"cold",
								"fire",
								"force",
								"lightning",
								"necrotic",
								"piercing",
								"poison",
								"psychic",
								"radiant",
								"slashing",
								"thunder"
							]
						},
						"uniqueItems": true
					},
					"damage_roll": { "type": "string", "minLength": 1 },
					"heal_roll": { "type": "string", "minLength": 1 },
					"hit_modifiers": { "type": "integer" },
					"DC": { "type": "integer", "minimum": 0 },
					"applied_status_effects": {
						"description": "Per-application status effects with their own durations",
						"type": "array",
						"items": {
							"type": "object",
							"additionalProperties": false,
							"required": ["status_effect_id", "duration"],
							"properties": {
								"status_effect_id": {
									"description": "Cross-reference to status_effects.json -> status_effect.id",
									"type": "string",
									"pattern": "^[a-z][a-z0-9_]*$"
								},
								"duration": {
									"type": "integer",
									"minimum": 0
								}
							}
						}
					}
				}
			}
		}
	}
}
