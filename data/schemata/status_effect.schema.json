{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "status_effect.schema.json",
	"title": "Status Effects",
	"type": "array",
	"items": {
		"type": "object",
		"additionalProperties": false,
		"required": ["id", "name", "description", "type", "parameters"],
		"properties": {
			"id": {
				"type": "string",
				"pattern": "^[a-z][a-z0-9_]*$"
			},
			"name": { "type": "string", "minLength": 1 },
			"description": { "type": "string" },
			"type": {
				"type": "string",
				"enum": [
					"attack_modifier",
					"ac_modifier",
					"DoT",
					"HoT",
					"control",
					"cc_immunity",
					"immunity",
					"resistance",
					"vulnerable"
				]
			},
			"parameters": {
				"type": "object",
				"additionalProperties": false,
				"properties": {
					"modifier": { "type": "integer" },
					"damage_types": {
						"type": "array",
						"items": {
							"type": "string",
							"enum": [
								"acid",
								"bludgeoning",
								"cold",
								"fire",
								"force",
								"lightning",
								"necrotic",
								"piercing",
								"poison",
								"psychic",
								"radiant",
								"slashing",
								"thunder"
							]
						},
						"uniqueItems": true
					},
					"damage_value": { "type": "integer", "minimum": 0 },
					"heal_value": { "type": "integer", "minimum": 0 },
					"control_type": {
						"type": "string",
						"enum": ["stunned", "asleep", "restrained", "silenced"]
					}
				}
			}
		}
	}
}
