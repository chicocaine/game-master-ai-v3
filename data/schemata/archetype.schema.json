{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "archetype.schema.json",
	"title": "Archetypes",
	"type": "array",
	"items": {
		"type": "object",
		"additionalProperties": false,
		"required": [
			"id",
			"name",
			"description",
			"hp_mod",
			"AC_mod",
			"spell_slot_mod",
			"initiative_mod",
			"resistances",
			"immunities",
			"vulnerabilities",
			"cc_immunities",
			"weapon_constraints",
			"known_spell_ids",
			"known_attack_ids"
		],
		"properties": {
			"id": {
				"type": "string",
				"pattern": "^[a-z][a-z0-9_]*$"
			},
			"name": { "type": "string", "minLength": 1 },
			"description": { "type": "string" },
			"hp_mod": { "type": "integer" },
			"AC_mod": { "type": "integer" },
			"spell_slot_mod": { "type": "integer" },
			"initiative_mod": { "type": "integer" },
			"resistances": { "$ref": "#/$defs/damageTypeArray" },
			"immunities": { "$ref": "#/$defs/damageTypeArray" },
			"vulnerabilities": { "$ref": "#/$defs/damageTypeArray" },
			"cc_immunities": {
				"type": "array",
				"items": {
					"type": "string",
					"enum": ["stunned", "asleep", "restrained", "silenced"]
				},
				"uniqueItems": true
			},
			"weapon_constraints": {
				"type": "object",
				"additionalProperties": false,
				"required": ["proficiency", "handling", "weight_class", "delivery", "magic_type"],
				"properties": {
					"proficiency": {
						"type": "array",
						"items": {
							"type": "string",
							"enum": ["simple", "martial", "exotic", "arcane", "divine", "tech"]
						},
						"uniqueItems": true
					},
					"handling": {
						"type": "array",
						"items": {
							"type": "string",
							"enum": ["one_handed", "two_handed", "versatile"]
						},
						"uniqueItems": true
					},
					"weight_class": {
						"type": "array",
						"items": {
							"type": "string",
							"enum": ["light", "heavy"]
						},
						"uniqueItems": true
					},
					"delivery": {
						"type": "array",
						"items": {
							"type": "string",
							"enum": ["melee", "ranged", "versatile"]
						},
						"uniqueItems": true
					},
					"magic_type": {
						"type": "array",
						"items": {
							"type": "string",
							"enum": ["mundane", "enchanted", "focus", "augment"]
						},
						"uniqueItems": true
					}
				}
			},
			"known_spell_ids": {
				"description": "Cross-reference to spells.json -> spell.id",
				"type": "array",
				"items": {
					"type": "string",
					"pattern": "^[a-z][a-z0-9_]*$"
				},
				"uniqueItems": true
			},
			"known_attack_ids": {
				"description": "Cross-reference to attacks.json -> attack.id",
				"type": "array",
				"items": {
					"type": "string",
					"pattern": "^[a-z][a-z0-9_]*$"
				},
				"uniqueItems": true
			}
		}
	},
	"$defs": {
		"damageTypeArray": {
			"type": "array",
			"items": {
				"type": "string",
				"enum": [
					"acid",
					"bludgeoning",
					"cold",
					"fire",
					"force",
					"lightning",
					"necrotic",
					"piercing",
					"poison",
					"psychic",
					"radiant",
					"slashing",
					"thunder"
				]
			},
			"uniqueItems": true
		}
	}
}
